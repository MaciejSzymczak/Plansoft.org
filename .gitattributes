# Delphi 7 source files: Windows-1250 (CP1250), no BOM, CRLF line endings.
# Do not let editors/tools re-save these as UTF-8 - it silently corrupts Polish
# diacritics throughout the whole file, not just the touched line.
*.pas text eol=crlf
*.dfm text eol=crlf
*.dpr text eol=crlf
*.inc text eol=crlf
*.dof text eol=crlf
*.cfg text eol=crlf

# Compiled/generated artifacts - never treat as text, never diff.
*.dcu binary
*.ddp binary
*.exe binary
*.dll binary
*.res binary
*.zip binary
*.dmp binary
